# ============================================
# DATA SENSITIF (HARUS PRIVATE)
# ============================================
data/raw/*.csv
data/raw/*.xlsx
data/processed/*.csv
data/processed/*.json

# ============================================
# SCRIPTS (PRIVATE - HANYA .GITKEEP)
# ============================================
scripts/*.py
!scripts/.gitkeep

# ============================================
# NOTEBOOK FILES (TIDAK PERLU)
# ============================================
*.ipynb
.ipynb_checkpoints/
notebooks/

# ============================================
# OUTPUT FILES (BISA DIREMAKE)
# ============================================
output/figures/*.png
output/figures/*.html
!output/figures/.gitkeep

# ============================================
# GAMBAR UNTUK README (TETAP DI-TRACK)
# ============================================
# Folder gambar untuk README.md - JANGAN DI-IGNORE!
# images_project_energy_2026/  (jangan tambahkan baris ini)

# ============================================
# PYTHON & ENVIRONMENT
# ============================================
__pycache__/
*.pyc
.env
.venv
venv/

# ============================================
# IDE & OS
# ============================================
.vscode/
.idea/
.DS_Store
Thumbs.db

# ============================================
# STREAMLIT
# ============================================
.streamlit/

# ============================================
# TESTING
# ============================================
test_env.py


test_env.py
test_*.py
*_test.py
debug_*.py
.pytest_cache/
.tox/

# ============================================
# KEEP FOLDER STRUCTURE (tapi kosong)
# ============================================
!data/raw/.gitkeep
!data/processed/.gitkeep
!images_project_energy_2026/.gitkeep
!output/figures/.gitkeep
!output/tables/.gitkeep

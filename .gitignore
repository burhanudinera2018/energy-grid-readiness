# ============================================
# DATA SENSITIF (HARUS PRIVATE)
# ============================================

# Data mentah (copyright, tidak boleh publik)
data/raw/*.csv
data/raw/*.xlsx
data/raw/*.xls
data/raw/*.xlsm

# Data hasil processing (bisa berisi info teknis)
data/processed/*.csv
data/processed/*.json
data/processed/*.txt

# Screenshot internal
images_project_energy_2026/
images_project_energy_2026/**/*.png
images_project_energy_2026/**/*.jpg
images_project_energy_2026/**/*.jpeg

# ============================================
# SCRIPTS (OPTIONAL - BOLEH PRIVATE)
# ============================================

# Semua file .py di folder scripts (kecuali .gitkeep)
scripts/*.py
!scripts/.gitkeep

# ============================================
# NOTEBOOK FILES (TIDAK PERLU)
# ============================================
*.ipynb
*.ipynb_checkpoints/
.ipynb_checkpoints/
notebooks/
notebooks/**/*.ipynb

# ============================================
# OUTPUT FILES (BISA DIREMAKE SAAT RUN)
# ============================================
output/figures/*.png
output/figures/*.jpg
output/figures/*.jpeg
output/figures/*.html
output/tables/*.csv
output/tables/*.xlsx

# TAPI tetap upload folder kosong untuk struktur
!output/figures/.gitkeep
!output/tables/.gitkeep

